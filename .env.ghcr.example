# Пример для docker-compose.ghcr.yml — скопируйте в .env рядом с compose или экспортируйте в shell.
# Корень образов = ghcr.io/<владелец>/<репозиторий> в нижнем регистре (как в workflow после merge в main).
LLMSTART_GHCR_IMAGE_ROOT=ghcr.io/your-github-user-or-org/llmstart-fullstack-live
IMAGE_TAG=latest
