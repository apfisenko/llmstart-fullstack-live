# Корневой `.env` — в первую очередь для Telegram-бота (`python -m bot.main` из корня).
# Параметры процесса backend: БД, LLM, BACKEND_HOST / BACKEND_PORT, LOG_LEVEL,
# BACKEND_API_CLIENT_TOKEN, PROXY_URL, OPENROUTER_*, SYSTEM_PROMPT_PATH — см.
# backend/.env.example (при одном `.env` в корне допишите оттуда нужные строки).

TELEGRAM_TOKEN=

# Бот → backend API: для режима с БД задайте оба UUID (см. README). Без них — guest-диалог только в памяти backend (без cohort/membership).
COHORT_ID=
MEMBERSHIP_ID=
# Необязательно: полный URL API; иначе http://127.0.0.1:8000 (совпадает с дефолтами backend).
BACKEND_BASE_URL=
# Таймаут HTTP-запросов бота к backend (секунды); в backend/.env.example нет — только здесь.
BACKEND_REQUEST_TIMEOUT=120
# Прокси для Telegram (aiogram). На запросы к backend не влияет — к API идёт прямое подключение.
PROXY_URL=
# Только если backend нужно вызывать через отдельный прокси (редко):
BACKEND_HTTP_PROXY=
