# Файл `bot/.env` — переменные Telegram-бота (`make run` / `uv run python -m bot.main` из корня).
# Бот читает только этот файл (см. `bot/config.py`). Не дублируйте сюда секреты backend, кроме
# того, что нужно боту для HTTP к API (токен клиента, URL, таймауты, прокси к Telegram).
# Backend: БД, LLM, логирование — только в `backend/.env` (см. `backend/.env.example`).

TELEGRAM_TOKEN=

# Бот → backend API: для режима с БД задайте оба UUID (см. README). Без них — guest-диалог только в памяти backend (без cohort/membership).
COHORT_ID=
MEMBERSHIP_ID=
# Необязательно: полный URL API; иначе http://127.0.0.1:8000 (совпадает с дефолтами backend).
BACKEND_BASE_URL=
# Таймаут HTTP-запросов бота к backend (секунды); в backend/.env.example нет — только здесь.
BACKEND_REQUEST_TIMEOUT=120
# Прокси для Telegram (aiogram). Оставьте пустым, если не нужен: иначе при недоступном прокси —
# таймауты и ошибки при отправке ответа в чат (ProxyTimeoutError). На httpx→backend не влияет.
PROXY_URL=
# Только если backend нужно вызывать через отдельный прокси (редко):
BACKEND_HTTP_PROXY=
