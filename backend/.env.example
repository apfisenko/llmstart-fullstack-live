# Скопировать в backend/.env. Все параметры backend (включая БД) — только из этого файла
# (приложение читает env_file=".env" относительно cwd, обычно каталог backend/).

# --- База данных (только PostgreSQL, async) ---
DATABASE_URL=postgresql+asyncpg://llmstart:llmstart@127.0.0.1:5432/llmstart
# Alembic: та же переменная; в migrations/env.py +asyncpg заменяется на +psycopg2.

# Локальный Postgres: из корня `make db-up`. С хоста — 127.0.0.1; из контейнера в той же сети — `postgres`.

# --- Процесс HTTP-сервера ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
LOG_LEVEL=INFO

BACKEND_API_CLIENT_TOKEN=

# --- LLM ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT=30

SYSTEM_PROMPT_PATH=bot/prompts/system.txt
PROXY_URL=
