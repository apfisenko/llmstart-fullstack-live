# Скопировать в .env в корне репозитория и/или в backend/.env.
# Settings загружает оба файла: (".env", "../.env") относительно cwd процесса — обычно запуск из backend/ (см. app/config.py).

# --- База данных ---
# Если переменная не задана или пустая — SQLite ./llmstart_local.sqlite в текущем каталоге процесса.
# Для прод и Alembic: задайте PostgreSQL, например:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/llmstart

# --- Процесс HTTP-сервера ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
LOG_LEVEL=INFO

# Общий секрет клиента (бот/веб) для маршрутов /api/v1/*. Если пусто или не задано — Bearer не проверяется (удобно для локалки).
BACKEND_API_CLIENT_TOKEN=

# --- LLM (OpenAI-совместимый Chat Completions, по умолчанию OpenRouter) ---
# Имена совпадают с корневым .env: один файл для бота и backend.
# Пустой ключ → заглушка LLM (достаточно для /health и тестов); для реальных ответов модели задайте ключ.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT=30

# Системный промпт ассистента: путь относительно текущего рабочего каталога процесса или абсолютный.
SYSTEM_PROMPT_PATH=bot/prompts/system.txt

# Опционально: прокси для исходящих HTTPS-запросов к провайдеру.
PROXY_URL=
